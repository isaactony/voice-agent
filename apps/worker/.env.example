NODE_ENV=development
LOG_LEVEL=info

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=lk_api_key
LIVEKIT_API_SECRET=lk_api_secret
LIVEKIT_AGENT_NAME=support-agent

OPENAI_API_KEY=sk-...
OPENAI_REALTIME_MODEL=gpt-realtime

# Turn-taking and interruption tuning (Node.js values are in milliseconds).
TURN_DETECTION_MODE=realtime_llm
TURN_ENDPOINTING_MIN_DELAY_MS=450
TURN_ENDPOINTING_MAX_DELAY_MS=1800
INTERRUPTION_ENABLED=true
INTERRUPTION_MODE=adaptive
INTERRUPTION_MIN_DURATION_MS=500
INTERRUPTION_MIN_WORDS=0
INTERRUPTION_FALSE_TIMEOUT_MS=2000
INTERRUPTION_RESUME_FALSE=true
INTERRUPTION_DISCARD_AUDIO_IF_UNINTERRUPTIBLE=true

CARTESIA_VOICE_ID=9626c31c-bec5-4cca-baa8-f8ba9e84c8bc
CARTESIA_LANGUAGE=en

DATABASE_URL=postgres://postgres:postgres@localhost:5432/voice_agent
REDIS_URL=redis://localhost:6379
