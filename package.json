{
  "name": "voice-agent-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:server dev:worker",
    "dev:frontend": "npm run dev -w @voice-agent/frontend",
    "dev:server": "npm run dev -w @voice-agent/server",
    "dev:worker": "npm run dev -w @voice-agent/worker",
    "build": "npm run build -ws",
    "typecheck": "npm run typecheck -ws",
    "lint": "npm run lint -ws"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
